# SymbioTech Backend — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to version control.

# Server
PORT=5000
NODE_ENV=development

# Frontend URL (CORS — must match exactly, no trailing slash)
FRONTEND_URL=http://localhost:3000

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=symbiotech
DB_USER=postgres
DB_PASSWORD=CHANGE_THIS_TO_YOUR_ACTUAL_PASSWORD

# ─────────────────────────────────────────────────────────────────────────────
# JWT Secret
# SECURITY: This MUST be a long, random, unpredictable string.
# The server will REFUSE to start if this is shorter than 32 characters
# or if it is not set at all.
#
# Generate a secure secret with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
#
# NEVER use "symbiotech_secret_key_123" or any dictionary phrase in production.
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_OUTPUT_OF_COMMAND_ABOVE

# AI Engine URL (optional — built-in Node.js matching used if not set)
# AI_ENGINE_URL=http://localhost:8000
